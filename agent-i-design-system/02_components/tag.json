    "purpose": "Tag is a component that visually indicates the category or state of content as a label. It distinguishes AI-related statuses and priorities using colors and styles.",
    "anatomy": [
      "Label",
      "Container"
    ],
    "style": {
      "type": {
        "solid": "Solid background for high visibility.",
        "outline": "Bordered style for secondary information."
      },
      "color_mapping": {
        "AI Status": "Specific colors for AI processing states.",
        "Priority": "Differentiated by color intensity."
      }
    },
    "usage_guidelines": [
      "Use to indicate content categories or system status.",
      "Vary styles to represent different levels of information importance."
    ],
