{
  "name": "Score",
  "tier": "02_components",
  "key": "score",
  "type": "atom",
  "description": "A component for visually displaying user ratings with stars and numerical scores.",
  "guidelines": {
    "purpose": "Score is a component that visually displays user ratings using stars and numerical score values. It is used for displaying evaluations of products, services, and content.",
    "anatomy": {
      "default": "Includes a lead score number, a row of 5 stars, and a trailing review count (e.g., 5.0 ★★★★☆ (999)).",
      "simple": "Includes a single star, a lead score number, and a trailing review count (e.g., ★ 5.0 (999))."
    },
    "variants": {
      "default-medium": "Score number + 5 stars + Review count",
      "default-small": "Small size version of default",
      "simple-medium": "1 star + Score number + Review count",
      "simple-small": "Small size version of simple"
    },
    "specs": {
      "star_size": {
        "medium": "20 x var(--sizing-500)",
        "small": "16 x var(--sizing-400)"
      },
      "star_colors": {
        "filled": "var(--color-content-warning) (amber)",
        "empty": "var(--color-background-tertiary)"
      },
      "typography": {
        "lead_text": "var(--sizing-300), 500 weight, var(--color-content-secondary)",
        "trail_text": "var(--sizing-300), var(--color-content-tertiary)"
      }
    },
    "_rawHtml": "\n<h2 class=\"section-title\">Guide</h2>\n        <div class=\"guide-card\">\n\n          <!-- Purpose -->\n          <div class=\"guide-block\">\n            <h3 class=\"guide-heading\">Purpose</h3>\n            <p class=\"guide-body\">Scoreは、ユーザーの評価を星とスコア数値で視覚的に表示するコンポーネントです。商品・サービス・コンテンツの評価表示に使用します。</p>\n          </div>\n\n          <!-- Anatomy -->\n          <div class=\"guide-block\">\n            <h3 class=\"guide-heading\">Anatomy</h3>\n            <div style=\"display:flex;gap:var(--spacing-1000);flex-wrap:wrap;padding:var(--spacing-500) 0;align-items:flex-start;\">\n              <div style=\"display:flex;flex-direction:column;align-items:center;gap:var(--spacing-300);\">\n                <div id=\"guide-score-default-demo\" style=\"padding:var(--spacing-200) 0;\"></div>\n                <span style=\"font-size: var(--text-size-xs);;color: var(--color-content-tertiary);text-align:center;\">default (medium)</span>\n              </div>\n              <div style=\"display:flex;flex-direction:column;align-items:center;gap:var(--spacing-300);\">\n                <div id=\"guide-score-simple-demo\" style=\"padding:var(--spacing-200) 0;\"></div>\n                <span style=\"font-size: var(--text-size-xs);;color: var(--color-content-tertiary);text-align:center;\">simple (medium)</span>\n              </div>\n              <div style=\"display:flex;flex-direction:column;align-items:center;gap:var(--spacing-300);\">\n                <div id=\"guide-score-default-sm-demo\" style=\"padding:var(--spacing-200) 0;\"></div>\n                <span style=\"font-size: var(--text-size-xs);;color: var(--color-content-tertiary);text-align:center;\">default (small)</span>\n              </div>\n              <div style=\"display:flex;flex-direction:column;align-items:center;gap:var(--spacing-300);\">\n                <div id=\"guide-score-simple-sm-demo\" style=\"padding:var(--spacing-200) 0;\"></div>\n                <span style=\"font-size: var(--text-size-xs);;color: var(--color-content-tertiary);text-align:center;\">simple (small)</span>\n              </div>\n            </div>\n            <script>\n            (function() {\n              var p = 'M10 1.5L12.245 7.046L18.271 7.796L13.636 12.296L14.99 18.247L10 15.368L5.01 18.247L6.364 12.296L1.729 7.796L7.755 7.046Z';\n              var full = DS_UTILS.icon('star_solid', { size: 24, color: 'var(--color-content-warning)' });\n              var half = DS_UTILS.icon('star_solid', { size: 24, color: 'var(--color-content-warning)' });\n              var stars5 = full+full+full+full+half;\n              var star1  = full;\n              var defs = [\n                ['guide-score-default-demo',    'score',       '<span class=\"score__lead\">5.0</span><div class=\"score__stars\">'+stars5+'</div><span class=\"score__trail\">(999)</span>'],\n                ['guide-score-simple-demo',     'score',       '<div class=\"score__stars\">'+star1+'</div><span class=\"score__lead\">5.0</span><span class=\"score__trail\">(999)</span>'],\n                ['guide-score-default-sm-demo', 'score score--sm', '<span class=\"score__lead\">5.0</span><div class=\"score__stars\">'+stars5+'</div><span class=\"score__trail\">(999)</span>'],\n                ['guide-score-simple-sm-demo',  'score score--sm', '<div class=\"score__stars\">'+star1+'</div><span class=\"score__lead\">5.0</span><span class=\"score__trail\">(999)</span>'],\n              ];\n              defs.forEach(function(d) {\n                var el = document.getElementById(d[0]);\n                if (el) el.innerHTML = '<div class=\"'+d[1]+'\">'+d[2]+'</div>';\n              });\n            })();\n            </script>\n          </div>\n\n          <!-- Variants -->\n          <div class=\"guide-block\">\n            <h3 class=\"guide-heading\">Variants</h3>\n            <table style=\"width:100%;border-collapse:collapse;font-size: var(--text-size-xs);;\">\n              <thead>\n                <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border);\">\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Type</th>\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Size</th>\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Preview</th>\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Description</th>\n                </tr>\n              </thead>\n              <tbody id=\"guide-score-variants-tbody\">\n              </tbody>\n            </table>\n            <script>\n            (function() {\n              var p = 'M10 1.5L12.245 7.046L18.271 7.796L13.636 12.296L14.99 18.247L10 15.368L5.01 18.247L6.364 12.296L1.729 7.796L7.755 7.046Z';\n              var full = DS_UTILS.icon('star_solid', { size: 24, color: 'var(--color-content-warning)' });\n              var half = DS_UTILS.icon('star_solid', { size: 24, color: 'var(--color-content-warning)' });\n              var stars5 = full+full+full+full+half;\n              var rows = [\n                ['default','medium','<div class=\"score\"><span class=\"score__lead\">5.0</span><div class=\"score__stars\">'+stars5+'</div><span class=\"score__trail\">(999)</span></div>','スコア数値 + 5星 + レビュー数'],\n                ['default','small', '<div class=\"score score--sm\"><span class=\"score__lead\">5.0</span><div class=\"score__stars\">'+stars5+'</div><span class=\"score__trail\">(999)</span></div>','スモールサイズ'],\n                ['simple', 'medium','<div class=\"score\"><div class=\"score__stars\">'+full+'</div><span class=\"score__lead\">5.0</span><span class=\"score__trail\">(999)</span></div>','1星 + スコア数値 + レビュー数'],\n                ['simple', 'small', '<div class=\"score score--sm\"><div class=\"score__stars\">'+full+'</div><span class=\"score__lead\">5.0</span><span class=\"score__trail\">(999)</span></div>','スモールサイズ'],\n              ];\n              var tb = document.getElementById('guide-score-variants-tbody');\n              if (tb) {\n                tb.innerHTML = rows.map(function(r,i) {\n                  var border = i < rows.length-1 ? 'border-bottom:var(--border-width-100) solid var(--shell-border)' : '';\n                  return '<tr style=\"'+border+'\"><td style=\"padding:var(--space-lg) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">'+r[0]+'</td><td style=\"padding:var(--space-lg) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">'+r[1]+'</td><td style=\"padding:var(--space-lg) 0;\">'+r[2]+'</td><td style=\"padding:var(--space-lg) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">'+r[3]+'</td></tr>';\n                }).join('');\n              }\n            })();\n            </script>\n          </div>\n\n          <!-- Specs -->\n          <div class=\"guide-block\">\n            <h3 class=\"guide-heading\">Specs</h3>\n            <table style=\"width:100%;border-collapse:collapse;font-size: var(--text-size-xs);;\">\n              <thead>\n                <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border);\">\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Property</th>\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Value</th>\n                </tr>\n              </thead>\n              <tbody>\n                <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border);\">\n                  <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">Star size (medium)</td>\n                  <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">20 × var(--sizing-500)</td>\n                </tr>\n                <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border);\">\n                  <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">Star size (small)</td>\n                  <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">16 × var(--sizing-400)</td>\n                </tr>\n                <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border);\">\n                  <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">Star color (filled)</td>\n                  <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--color-content-warning) (amber)</td>\n                </tr>\n                <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border);\">\n                  <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">Star color (empty)</td>\n                  <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--color-background-tertiary)</td>\n                </tr>\n                <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border);\">\n                  <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">Leading text (score)</td>\n                  <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--sizing-300) · 500 · var(--color-content-secondary)</td>\n                </tr>\n                <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border);\">\n                  <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">Trailing text (count)</td>\n                  <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--sizing-300) · var(--color-content-tertiary)</td>\n                </tr>\n                <tr>\n                  <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">Gap</td>\n                  <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--sizing-100)</td>\n                </tr>\n              </tbody>\n            </table>\n          </div>\n\n          <!-- Usage -->\n          <div class=\"guide-block\">\n            <h3 class=\"guide-heading\">Usage</h3>\n            <p class=\"guide-body\">商品カード・レビューセクション・詳細ページなど、ユーザー評価を視覚的に伝える場面で使用します。</p>\n            <div class=\"do-dont-grid\" style=\"margin-top:var(--spacing-300);\">\n              <div class=\"do-card\">\n                <div class=\"do-card-header\">✓ DO</div>\n                <div class=\"do-card-body\">\n                  <p>スコア数値と星を常にセットで表示する</p>\n                  <p>レビュー数を括弧付きで添える（信頼性の補強）</p>\n                </div>\n              </div>\n              <div class=\"dont-card\">\n                <div class=\"dont-card-header\">✗ DON'T</div>\n                <div class=\"dont-card-body\">\n                  <p>星だけを単独で使用しない（数値を必ず添える）</p>\n                  <p>5段階以外のスケールに星を流用しない</p>\n                </div>\n              </div>\n            </div>\n          </div>\n\n        </div><!-- guide-card -->\n  "
  },
  "selector": ".score"
}