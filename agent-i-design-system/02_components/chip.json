          "default": false
        },
        {
          "id": "chipLabel",
          "label": "Chip label",
          "type": "text",
          "default": "Chip"
        },
        {
          "id": "showLeftIcon",
          "label": "Show left icon",
          "type": "toggle",
          "options": [
            false,
            true
