  "key": "chip",
  "type": "atom",
  "description": "UI element for representing small units of information like actions, tags, filters, or options.",
  "guidelines": {
    "purpose": "Chip is a UI element meant to represent small units of information such as simple actions, tags, filter selections, and option displays. Users can quickly switch contexts by selecting/toggling Chips accompanied by short text or icons.",
    "anatomy": [
      "Container",
      "Label",
      "Graphic (optional)",
      "Left / Right icon (optional)"
    ],
    "variants": {
      "solid-rounded-rect": "Solid type Chip with a rounded rectangular shape, providing a stable visual style.",
      "solid-rounded": "Pill-shaped Solid Chip with stronger rounding, providing a soft and casual visual expression.",
      "outline-gradient": "Chip with a gradient outline, functioning as a more decorative and emphasized visual style."
    },
    "style": {
      "size": {
        "xlarge": "var(--sizing-1200)",
        "large": "var(--sizing-1000)",
        "medium": "var(--sizing-800)",
        "small": "var(--sizing-700)"
      },
      "state": [
        "enabled",
        "hovered",
        "focused",
        "pressed",
        "disabled"
      ],
      "selected": [
        "on",
        "off"
      ],
      "icon_controls": [
        "Left Icon ON/OFF",
        "Right Icon ON/OFF",
        "Icon swap"
      ]
    },
    "usage_guidelines": [
      "Suitable for communicating concise text and simple actions.",
      "When placing multiple Chips, maintain consistency by using the same size/style."
    ],
    "do_dont": {
      "do": [
        "Keep the Selected state visually distinct.",
        "Use icons/avatars only when necessary for meaning communication.",
        "Use Small size for high-density information areas or auxiliary tags/labels.",
        "Prioritize Medium size for primary actions like filter triggers or starting searches."
      ],
      "dont": [
        "Do not use excessively long text in a Chip."
      ]
    },
    "playground": {
      "controls": [
        {
          "id": "variant",
          "label": "Variant",
          "type": "toggle",
          "options": [
            "solid-rounded-rect",
            "solid-rounded",
            "outline-gradient"
          ],
          "default": "solid-rounded-rect"
        },
        {
          "id": "size",
          "label": "Size",
          "type": "toggle",
          "options": [
            "small",
