{
  "name": "Checkbox",
  "tier": "02_components",
  "key": "checkbox",
  "type": "atom",
  "description": "An input component for users to select/deselect one or more items.",
  "guidelines": {
    "purpose": "Checkbox is an input component for users to select or deselect one or more items. It is used when multiple selections are possible, and the selection state is maintained.",
    "anatomy": {
      "background_area": "The checkbox box itself.",
      "icon_area": "The checkmark icon.",
      "label": "Text label placed outside the checkbox wrap."
    },
    "style": {
      "state": [
        "enabled",
        "hovered",
        "focused",
        "pressed",
        "disabled"
      ],
      "selected": [
        "true",
        "false"
      ]
    },
    "usage_guidelines": {
      "general": [
        "Maintains selected state after user interaction.",
        "Labels should be placed outside the checkbox; the component itself does not include text.",
        "Maintain consistent placement and spacing when aligning multiple checkboxes."
      ],
      "spacing": {
        "horizontal_gap": "var(--sizing-200) between checkbox and label.",
        "vertical_gap": "Minimum var(--sizing-400) between vertical checkboxes.",
        "adjustment": "Adjust in var(--sizing-100) units."
      },
      "touch_target": "The touch area includes the label. Total touch target should be at least 44xvar(--sizing-1100) for mobile.",
      "playground": {
        "controls": [
          {
            "id": "checked",
            "label": "Checked",
            "type": "toggle",
            "options": [
              true,
              false
            ],
            "default": false
          },
          {
            "id": "label",
            "label": "Label",
            "type": "text",
            "default": "Checkbox Label"
          },
          {
            "id": "state",
