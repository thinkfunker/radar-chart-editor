{
  "name": "Badge",
  "tier": "02_components",
  "key": "badge",
  "type": "atom",
  "description": "An auxiliary UI component for expressing new notifications, updates, or unread status.",
  "guidelines": {
    "purpose": "Badge is an auxiliary UI component for expressing and drawing attention to new notifications, updates, or unread status. It does not function alone and is used in combination with components like Avatar, Icon, or Tab.",
    "anatomy": [
      "Text (Number): Displays notification or unread counts with digits.",
      "Background/Area: Background color area for enhanced visibility.",
      "Dot (Dot type): Presence notification indicator without numerical values."
    ],
    "type": {
      "Number": "Displays quantity information, such as notification or unread counts. Contains one or more digits.",
      "Dot": "Used as a dot to indicate new movements or presence. Also used in place of Number type when space is limited."
    },
    "style": {
      "priority": {
        "Primary": "Gradient var(--color-gradient-content-stop-1) to var(--color-content-key), Text var(--color-background-white). Used when strong attention is required.",
        "Secondary": "var(--color-border-secondary), Text var(--color-content-primary). Used to emphasize information within the design."
      },
      "size": {
        "Number": {
          "small": "var(--sizing-400) height, min-w var(--sizing-400), var(--font-size-0687) bold font",
          "medium": "var(--sizing-800) height, min-w var(--sizing-800), var(--sizing-400) bold font"
        },
        "Dot": {
          "small": "8 x var(--sizing-200)",
          "medium": "12 x var(--sizing-300)"
        }
      }
    },
    "_rawHtml": "\n<div class=\"guide-section\">\n            <div class=\"guide-title\">Purpose</div>\n            <div class=\"guide-body\">\n              Badgeは、新しい通知・更新・未読省を表現し注目させるための補助的UIコンポーネントです。単体では機能せず、Avatar、Icon、Tabなどと合わせたコンポーネントとして使用します。\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Anatomy</div>\n            <div class=\"guide-body\">\n              <ul>\n                <li><strong>Text (Number)</strong> — 通知や未読数を数字で表示</li>\n                <li><strong>Background/Area</strong> — 視認性を高める背景色エリア</li>\n                <li><strong>Dot (Dot type)</strong> — 数値なしの存在通知インジケーター</li>\n              </ul>\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Type</div>\n            <div class=\"guide-body\">\n              <p style=\"font-weight:600;margin-bottom:var(--spacing-200);\">Number</p>\n              <ul>\n                <li>数量情報を表示します。</li>\n                <li>通知数、未読数確認などの用途に使います。</li>\n                <li>数字は1文字以上入ります。</li>\n              </ul>\n              <p style=\"font-weight:600;margin-top:var(--spacing-400);margin-bottom:var(--spacing-200);\">Dot</p>\n              <ul>\n                <li>新しい動きや存在感を示す点として使います。</li>\n                <li>スペースの都合でも使えドットタイプは Numberタイプの代わりに使用します。</li>\n              </ul>\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Style</div>\n            <div class=\"guide-body\">\n              <p style=\"font-weight:600;margin-bottom:var(--spacing-200);\">Priority</p>\n              <p>強い注意喚起が必要な場合には、高い Priority を使用します。</p>\n              <ul>\n                <li><strong>Primary</strong> — 入力テーマの基調色に合わせて Priority をまとめます。</li>\n                <li><strong>Secondary</strong> — Priority は、Designの中情報を強調する際に使います。</li>\n                <li>各権限のカラー基盤、Priority ごとにシステムで活用されたとなれる大きさを管理します。</li>\n              </ul>\n              <table style=\"width:100%;border-collapse:collapse;font-size: var(--text-size-xs);;margin-top:var(--spacing-300);\">\n                <thead><tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border);\">\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Priority</th>\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Background</th>\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Text Color</th>\n                </tr></thead>\n                <tbody>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\">\n                    <td style=\"padding:var(--space-md) 0;\"><code style=\"font-size: var(--text-size-xs);;background:var(--color-background-overlay-white);padding:var(--spacing-050) var(--space-xxs);border-radius:var(--border-width-300);color:var(--color-content-key);\">primary</code></td>\n                    <td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">gradient var(--color-gradient-content-stop-1)→var(--color-content-key)</td>\n                    <td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\"><code style=\"font-size: var(--text-size-xs);;\">--content/inverted = var(--color-background-white)</code></td>\n                  </tr>\n                  <tr>\n                    <td style=\"padding:var(--space-md) 0;\"><code style=\"font-size: var(--text-size-xs);;background:var(--color-background-overlay-white);padding:var(--spacing-050) var(--space-xxs);border-radius:var(--border-width-300);color:var(--color-content-key);\">secondary</code></td>\n                    <td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--color-border-secondary)</td>\n                    <td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\"><code style=\"font-size: var(--text-size-xs);;\">--content/primary = var(--color-content-primary)</code></td>\n                  </tr>\n                </tbody>\n              </table>\n\n              <p style=\"font-weight:600;margin-top:var(--spacing-500);margin-bottom:var(--spacing-200);\">Size</p>\n              <table style=\"width:100%;border-collapse:collapse;font-size: var(--text-size-xs);;\">\n                <thead><tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border);\">\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Type</th>\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Size</th>\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Dimensions</th>\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Font</th>\n                </tr></thead>\n                <tbody>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\">\n                    <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Number</td>\n                    <td><code style=\"font-size: var(--text-size-xs);;background:var(--color-background-overlay-white);padding:var(--spacing-050) var(--space-xxs);border-radius:var(--border-width-300);color:var(--color-content-key);\">small</code></td>\n                    <td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--sizing-400) height, min-w var(--sizing-400)</td>\n                    <td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--font-size-0687) bold</td>\n                  </tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\">\n                    <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Number</td>\n                    <td><code style=\"font-size: var(--text-size-xs);;background:var(--color-background-overlay-white);padding:var(--spacing-050) var(--space-xxs);border-radius:var(--border-width-300);color:var(--color-content-key);\">medium</code></td>\n                    <td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--sizing-800) height, min-w var(--sizing-800)</td>\n                    <td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--sizing-400) bold</td>\n                  </tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\">\n                    <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Dot</td>\n                    <td><code style=\"font-size: var(--text-size-xs);;background:var(--color-background-overlay-white);padding:var(--spacing-050) var(--space-xxs);border-radius:var(--border-width-300);color:var(--color-content-key);\">small</code></td>\n                    <td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">8 × var(--sizing-200)</td>\n                    <td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">—</td>\n                  </tr>\n                  <tr>\n                    <td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Dot</td>\n                    <td><code style=\"font-size: var(--text-size-xs);;background:var(--color-background-overlay-white);padding:var(--spacing-050) var(--space-xxs);border-radius:var(--border-width-300);color:var(--color-content-key);\">medium</code></td>\n                    <td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">12 × var(--sizing-300)</td>\n                    <td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">—</td>\n                  </tr>\n                </tbody>\n              </table>\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Usage Guidelines</div>\n            <div class=\"guide-body\">\n              <p style=\"font-weight:600;margin-bottom:var(--space-xs);\">Avatar</p>\n              <ul>\n                <li>Number タイプの Badge は Avatar の右下に配置します。</li>\n                <li>Dot タイプの Badge は Avatar の右下に配置します。</li>\n                <li>配置のオフセット値（右・下）は Avatar 背景要素の大きさで、位置調整してください。</li>\n              </ul>\n              <p style=\"font-weight:600;margin-top:var(--spacing-400);margin-bottom:var(--space-xs);\">Icon</p>\n              <ul>\n                <li>Iconの右上の上に配置します。</li>\n                <li>Icon の最小サイズは 24×24 を基準とします。</li>\n              </ul>\n              <p style=\"font-weight:600;margin-top:var(--spacing-400);margin-bottom:var(--space-xs);\">Tab</p>\n              <ul>\n                <li>新しい動きや変更がある場合、Tab の Label と一緒に Badge を表示できます。</li>\n                <li>符号として使われることもあれば Dot タイプを使用します。</li>\n              </ul>\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Do &amp; Don't</div>\n            <div class=\"guide-body\">\n              <p style=\"font-weight:600;margin-bottom:var(--space-xs);\">Do</p>\n              <ul>\n                <li>Badge が使用されるコンポーネントを含まないようにして配置します。</li>\n                <li>コンポーネントのサイズに応じて Badge の Size（Small / Medium）を選択します。</li>\n                <li>スペースの並び許す場合は Dot タイプを使用します。</li>\n              </ul>\n              <p style=\"font-weight:600;margin-top:var(--spacing-400);margin-bottom:var(--space-xs);\">Don't</p>\n              <ul>\n                <li>Badge を単体で使用しない。</li>\n                <li>100 を超える数字は表示しません。</li>\n                <li>コンポーネントのサイズと合わない Badge サイズを使用しません。</li>\n              </ul>\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Code</div>\n            <div class=\"guide-body\">\n              <pre style=\"background:var(--color-content-primary);border:var(--border-width-100) solid var(--shell-border);border-radius:var(--border-radius-200);padding:var(--spacing-400);font-size: var(--text-size-xs);;line-height:1.7;overflow-x:auto;color:var(--color-content-inverted);margin-top:var(--spacing-200);\"><code><span style=\"color:var(--color-content-tertiary)\">&lt;!-- Number / Primary / Small --&gt;</span>\n<span style=\"color:var(--color-content-key)\">&lt;span</span> <span style=\"color:var(--color-content-key)\">class</span>=<span style=\"color:var(--color-content-success)\">\"badge badge--number badge--primary badge--small\"</span><span style=\"color:var(--color-content-key)\">&gt;</span>3<span style=\"color:var(--color-content-key)\">&lt;/span&gt;</span>\n\n<span style=\"color:var(--color-content-tertiary)\">&lt;!-- Number / Secondary / Medium --&gt;</span>\n<span style=\"color:var(--color-content-key)\">&lt;span</span> <span style=\"color:var(--color-content-key)\">class</span>=<span style=\"color:var(--color-content-success)\">\"badge badge--number badge--secondary badge--medium\"</span><span style=\"color:var(--color-content-key)\">&gt;</span>99<span style=\"color:var(--color-content-key)\">&lt;/span&gt;</span>\n\n<span style=\"color:var(--color-content-tertiary)\">&lt;!-- Dot / Primary / Small --&gt;</span>\n<span style=\"color:var(--color-content-key)\">&lt;span</span> <span style=\"color:var(--color-content-key)\">class</span>=<span style=\"color:var(--color-content-success)\">\"badge badge--dot badge--primary badge--small\"</span><span style=\"color:var(--color-content-key)\">&gt;&lt;/span&gt;</span>\n\n<span style=\"color:var(--color-content-tertiary)\">&lt;!-- Avatar + Badge 組み合わせ --&gt;</span>\n<span style=\"color:var(--color-content-key)\">&lt;div</span> <span style=\"color:var(--color-content-key)\">class</span>=<span style=\"color:var(--color-content-success)\">\"badge-host\"</span><span style=\"color:var(--color-content-key)\">&gt;</span>\n  <span style=\"color:var(--color-content-key)\">&lt;div</span> <span style=\"color:var(--color-content-key)\">class</span>=<span style=\"color:var(--color-content-success)\">\"avatar avatar--medium avatar--user\"</span><span style=\"color:var(--color-content-key)\">&gt;</span>...<span style=\"color:var(--color-content-key)\">&lt;/div&gt;</span>\n  <span style=\"color:var(--color-content-key)\">&lt;span</span> <span style=\"color:var(--color-content-key)\">class</span>=<span style=\"color:var(--color-content-success)\">\"badge badge--number badge--primary badge--small badge-pos-br\"</span><span style=\"color:var(--color-content-key)\">&gt;</span>3<span style=\"color:var(--color-content-key)\">&lt;/span&gt;</span>\n<span style=\"color:var(--color-content-key)\">&lt;/div&gt;</span></code></pre>\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Design Tokens</div>\n            <div class=\"guide-body\">\n              <table style=\"width:100%;border-collapse:collapse;font-size: var(--text-size-xs);;\">\n                <thead><tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border);\">\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Property</th>\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Token / Value</th>\n                </tr></thead>\n                <tbody>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Primary BG</td><td><code style=\"font-size: var(--text-size-xs);;\">gradient: var(--color-gradient-content-stop-1) 5.1% → var(--color-content-key) 92.36%</code></td></tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Dot color</td><td><code style=\"font-size: var(--text-size-xs);;\">--content/notification = var(--color-content-notification)</code></td></tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Border Radius</td><td><code style=\"font-size: var(--text-size-xs);;\">--border-radius-full = var(--border-radius-full)</code></td></tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Small height</td><td><code style=\"font-size: var(--text-size-xs);;\">--sizing-400 = var(--sizing-400)</code></td></tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Medium height</td><td><code style=\"font-size: var(--text-size-xs);;\">--sizing-800 = var(--sizing-800)</code></td></tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Dot border</td><td><code style=\"font-size: var(--text-size-xs);;\">--border/inverted = white</code></td></tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Padding H</td><td><code style=\"font-size: var(--text-size-xs);;\">--spacing-100 = var(--sizing-100)</code></td></tr>\n                  <tr><td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Font size (small)</td><td><code style=\"font-size: var(--text-size-xs);;\">--size/0687 = var(--font-size-0687), bold</code></td></tr>\n                </tbody>\n              </table>\n            </div>\n          </div>\n    "
  },
  "selector": ".badge"
}