{
  "name": "AI Text Input",
  "tier": "03_blocks",
  "key": "ai-input",
  "type": "composition",
  "description": "Bottom input bar for AI chat interfaces.",
  "guidelines": {
    "summary": "AI Text Input is a core interaction component used to trigger user input and AI responses. It is designed so that various operations, such as text input, voice input, file/photo attachment, and message sending, can be executed in a single input field.",
    "anatomy": [
      "Left button (+)",
      "Input field (Placeholder / Cursor / Text)",
      "Right button (Mic / Send)",
      "Container (Background / Border radius / Border)"
    ],
    "style": {
      "type": {
        "Simple": "Supports single-line input.",
        "Multiple": "Supports multi-line input."
      },
      "state": [
        "enabled",
        "focused",
        "typing",
        "typed",
        "disabled"
      ],
      "icon_controls": [
        "Left button ON/OFF",
        "Left icon ON/OFF",
        "Right button 1 (Mic) ON/OFF",
        "Right button 2 (Send) ON/OFF"
      ],
      "left_menu": {
        "Description": "Controls the display state of the attachment menu (Photo/Camera/File) shown when the '+' button is pressed."
      }
    },
    "usage_guidelines": {
      "Text input": "The primary method for writing detailed questions or instructions.",
      "Floating layer": "The message input module should be exposed as a floating layer above the content.",
      "Left menu (Menu button)": "Provides expanded input methods, such as uploading photos, using the camera, or attaching files.",
      "Right button 1 (Mic button)": "Used as an alternative to text input in environments where voice input is available.",
      "Right button 2 (Send button)": "Activated only when text is present, sending the request to the AI."
    },
    "do_dont": {
      "do": [
        "💡 Display the attachment menu in a clearly separated position so it is not confused with the input field.",
        "💡 Enable the send button only when an input is clearly present."
      ],
      "dont": [
        "🚫 Avoid layouts where the attachment menu overlaps and obstructs the operation of surrounding elements.",
        "🚫 Do not rely exclusively on the microphone button for important operations."
      ]
    },
    "_rawHtml": "\n<div class=\"guide-section\">\n            <div class=\"guide-title\">Purpose</div>\n            <div class=\"guide-body\">AI Text Inputは、ユーザー入力とAI応答のトリガーを行う中心的なインタラクション部品です。テキスト入力、音声入力、ファイル/写真送付、メッセージ送信などを、単独の操作を1つの入力欄で実行できるよう設計されています。</div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Anatomy</div>\n            <div class=\"guide-body\">\n              <p style=\"font-weight:600;margin-bottom:var(--space-xs);\">構成要素</p>\n              <ul>\n                <li><strong>Left button (+)</strong> — 写真・カメラ・ファイルのメニューをトリガー</li>\n                <li><strong>Input field</strong> — プレースホルダー / カーソル / テキスト</li>\n                <li><strong>Mic button</strong> — 音声入力トリガー (Right button 1)</li>\n                <li><strong>Send button</strong> — テキスト有り時のみアクティブ (Right button 2)</li>\n                <li><strong>Container</strong> — 背景・角丸・ボーダー</li>\n              </ul>\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Type</div>\n            <div class=\"guide-body\">\n              <p>AI Text Inputは、単一入力（simple）と複数行入力（multiple）をサポートします。</p>\n            </div>\n            <div class=\"guide-example-box\" style=\"flex-direction:column; gap:var(--spacing-400); background: var(--color-background-secondary);\">\n              <div>\n                <div style=\"font-size: var(--text-size-xs);;color: var(--color-content-tertiary);font-family:monospace;margin-bottom:var(--spacing-200);\">Simple — height var(--sizing-1200)</div>\n                <div class=\"ai-input\" style=\"pointer-events:none;\">\n                  <button class=\"ai-input-left-btn\"><span data-ds-icon=\"plus_solid\" data-ds-size=\"24\" data-ds-color=\"currentColor\"></span></button>\n                  <div class=\"ai-input-field-wrap\"><span class=\"ai-input-placeholder\">なんでも聞いてください</span></div>\n                  <div class=\"ai-input-controls\">\n                    <button class=\"ai-input-mic-btn\"><span data-ds-icon=\"microphone_solid\" data-ds-size=\"24\" data-ds-color=\"currentColor\"></span></button>\n                    <button class=\"ai-input-send-btn\"><span data-ds-icon=\"paper-plane_solid\" data-ds-size=\"24\" data-ds-color=\"var(--color-background-white)\"></span></button>\n                  </div>\n                </div>\n              </div>\n              <div>\n                <div style=\"font-size: var(--text-size-xs);;color: var(--color-content-tertiary);font-family:monospace;margin-bottom:var(--spacing-200);\">Multiple — height var(--border-radius-full)</div>\n                <div class=\"ai-input multiple\" style=\"pointer-events:none; width:var(--size-ai-input-width);\">\n                  <div class=\"ai-input-field-wrap\" style=\"height:var(--sizing-1400);flex:1;align-self:flex-start;\">\n                    <span class=\"ai-input-placeholder\">なんでも聞いてください</span>\n                  </div>\n                  <div class=\"ai-input-controls\" style=\"align-self:flex-end;\">\n                    <button class=\"ai-input-left-btn\"><span data-ds-icon=\"plus_solid\" data-ds-size=\"24\" data-ds-color=\"currentColor\"></span></button>\n                    <button class=\"ai-input-mic-btn\"><span data-ds-icon=\"microphone_solid\" data-ds-size=\"24\" data-ds-color=\"currentColor\"></span></button>\n                    <button class=\"ai-input-send-btn\"><span data-ds-icon=\"paper-plane_solid\" data-ds-size=\"24\" data-ds-color=\"var(--color-background-white)\"></span></button>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Style — States</div>\n            <div class=\"guide-body\">\n              <p>入力欄は、ユーザーの操作に応じて以下の5種の状態を持ちます。</p>\n              <table style=\"width:100%;border-collapse:collapse;font-size: var(--text-size-xs);;margin-top:var(--spacing-300);\">\n                <thead><tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border);\">\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">State</th>\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Border</th>\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Send Button</th>\n                </tr></thead>\n                <tbody>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;\"><code style=\"font-size: var(--text-size-xs);;background:var(--color-background-overlay-white);padding:var(--spacing-050) var(--space-xxs);border-radius:var(--border-width-300);color:var(--color-content-key);\">enabled</code></td><td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--color-content-tertiary)</td><td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">disabled (gray)</td></tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;\"><code style=\"font-size: var(--text-size-xs);;background:var(--color-background-overlay-white);padding:var(--spacing-050) var(--space-xxs);border-radius:var(--border-width-300);color:var(--color-content-key);\">focused</code></td><td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--color-content-tertiary) + ring</td><td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">disabled、カーソル表示</td></tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;\"><code style=\"font-size: var(--text-size-xs);;background:var(--color-background-overlay-white);padding:var(--spacing-050) var(--space-xxs);border-radius:var(--border-width-300);color:var(--color-content-key);\">typing</code></td><td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--color-content-tertiary) + ring</td><td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">disabled、カーソル表示</td></tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;\"><code style=\"font-size: var(--text-size-xs);;background:var(--color-background-overlay-white);padding:var(--spacing-050) var(--space-xxs);border-radius:var(--border-width-300);color:var(--color-content-key);\">typed</code></td><td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--color-content-tertiary)</td><td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\"><strong style=\"color:var(--shell-text);\">active</strong> — gradient</td></tr>\n                  <tr><td style=\"padding:var(--space-md) 0;\"><code style=\"font-size: var(--text-size-xs);;background:var(--color-background-overlay-white);padding:var(--spacing-050) var(--space-xxs);border-radius:var(--border-width-300);color:var(--color-content-key);\">disabled</code></td><td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">var(--color-border-secondary)</td><td style=\"color:var(--shell-muted);font-size: var(--text-size-xs);;\">disabled</td></tr>\n                </tbody>\n              </table>\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Usage Guidelines</div>\n            <div class=\"guide-body\">\n              <p><strong>Text input</strong></p>\n              <ul><li>明確な質問や指示を書くための基本手段です。</li></ul>\n              <p style=\"margin-top:var(--space-lg);\"><strong>Left menu (Menu button)</strong></p>\n              <ul><li>写真・カメラ・ファイルのアップロードなど、入力の添付手段を提供します。</li></ul>\n              <p style=\"margin-top:var(--space-lg);\"><strong>Right button 1 (Mic button)</strong></p>\n              <ul><li>音声入力が利用できる場面で、テキスト入力の代替手段として提案されます。</li></ul>\n              <p style=\"margin-top:var(--space-lg);\"><strong>Right button 2 (Send button)</strong></p>\n              <ul><li>テキストが存在する場合のみ有効化され、AIの応答を送信します。</li></ul>\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Do &amp; Don't</div>\n            <div class=\"guide-body\">\n              <p><strong>Do</strong></p>\n              <ul>\n                <li>添付メニューと入力欄が視覚的に繋がるよう、メニューは状況に分かれた位置に表示します。</li>\n                <li>送付ボタンは、入力が存在する場合のみ有効化します。</li>\n              </ul>\n              <p style=\"margin-top:var(--spacing-300);\"><strong>Don't</strong></p>\n              <ul>\n                <li>添付メニューの認識操作を妨げないよう、重なりを避けます。</li>\n                <li>複数な操作をマイクロアイコンのみに委ねないでください。</li>\n              </ul>\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Design Tokens</div>\n            <div class=\"guide-body\">\n              <table style=\"width:100%;border-collapse:collapse;font-size: var(--text-size-xs);;\">\n                <thead><tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border);\">\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Property</th>\n                  <th style=\"text-align:left;padding:var(--spacing-200) 0;color:var(--shell-muted);font-weight:600;\">Value</th>\n                </tr></thead>\n                <tbody>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Height (simple)</td><td><code style=\"font-size: var(--text-size-xs);;\">--sizing-1200 = var(--sizing-1200)</code></td></tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Height (multiple)</td><td><code style=\"font-size: var(--text-size-xs);;\">var(--border-radius-full)</code></td></tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Border Radius</td><td><code style=\"font-size: var(--text-size-xs);;\">--border-radius-full = var(--border-radius-full)</code></td></tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Border (default)</td><td><code style=\"font-size: var(--text-size-xs);;\">var(--color-content-tertiary)</code></td></tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Padding H</td><td><code style=\"font-size: var(--text-size-xs);;\">--spacing-300 = var(--sizing-300)</code></td></tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--color-background-overlay-white);\"><td style=\"padding:var(--space-md) 0;color:var(--shell-muted);\">Send (active)</td><td><code style=\"font-size: var(--text-size-xs);;\">gradient: var(--color-gradient-content-stop-1) → var(--color-content-key)</code></td></tr>\n                  <tr><td style=\"padding:var(--radius-md) 0;color:var(--shell-muted);\">Send (disabled)</td><td><code style=\"font-size: var(--text-size-xs);;\">--background/disabled = var(--color-background-tertiary)</code></td></tr>\n                </tbody>\n              </table>\n            </div>\n          </div>\n    "
  },
  "selector": ".ai-input"
}
