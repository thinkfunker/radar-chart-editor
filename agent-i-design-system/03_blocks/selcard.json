{
  "name": "Selection Card",
  "tier": "03_blocks",
  "key": "selcard",
  "type": "composition",
  "description": "Two-step selection card system.",
  "guidelines": {
    "purpose": "Two-step selection card system.",
    "anatomy": [
      "var(--size-card-width-lg) wide, radius 16, 0.06 gradient bg.",
      "Not-selected: 2-col nav chips with chevron.",
      "Selected: 4-col option chips without chevron."
    ],
    "_rawHtml": "\n    <div class=\"guide-card\">\n      <div class=\"guide-section\">\n        <div class=\"guide-title\">Selection Card</div>\n        <div class=\"guide-body\">カテゴリ選択フロー用の2段階カードコンポーネントです。最初の画面（not selected）では2列グリッドでカテゴリ項目をchevron-rightアイコンとともに表示し、選択後（selected）では4列グリッドで詳細オプションを表示して最初の項目が強調（選択済み）状態になります。下部に確認ボタンが表示されます。</div>\n      </div>\n\n      <div class=\"guide-section\">\n        <div class=\"guide-subtitle\">Not selected — カテゴリ一覧（2列 × 4行）</div>\n        <div style=\"margin-top:var(--spacing-200);\">\n          <div class=\"selcard\" style=\"background:linear-gradient(37deg, var(--color-gradient-background-ai-surface-stop-1) 5.1%, var(--color-gradient-background-ai-surface-stop-2) 92.36%)\">\n            <div class=\"selcard__header\">\n              <div class=\"selcard__header-icon\">\n                <span data-ds-icon=\"question-text-circle_solid\" data-ds-size=\"24\" data-ds-color=\"var(--color-content-key)\"></span>\n              </div>\n              <span class=\"selcard__header-text\">Text</span>\n            </div>\n            <div class=\"selcard__chip-group\">\n              <div class=\"selcard__chip-row\">\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label\">Label</span><span class=\"selcard__chip-chevron\" data-ds-icon=\"chevron-right_solid\" data-ds-size=\"20\" data-ds-color=\"var(--color-content-tertiary)\"></span></div>\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label\">Label</span><span class=\"selcard__chip-chevron\" data-ds-icon=\"chevron-right_solid\" data-ds-size=\"20\" data-ds-color=\"var(--color-content-tertiary)\"></span></div>\n              </div>\n              <div class=\"selcard__chip-row\">\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label\">Label</span><span class=\"selcard__chip-chevron\" data-ds-icon=\"chevron-right_solid\" data-ds-size=\"20\" data-ds-color=\"var(--color-content-tertiary)\"></span></div>\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label\">Label</span><span class=\"selcard__chip-chevron\" data-ds-icon=\"chevron-right_solid\" data-ds-size=\"20\" data-ds-color=\"var(--color-content-tertiary)\"></span></div>\n              </div>\n              <div class=\"selcard__chip-row\">\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label\">Label</span><span class=\"selcard__chip-chevron\" data-ds-icon=\"chevron-right_solid\" data-ds-size=\"20\" data-ds-color=\"var(--color-content-tertiary)\"></span></div>\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label\">Label</span><span class=\"selcard__chip-chevron\" data-ds-icon=\"chevron-right_solid\" data-ds-size=\"20\" data-ds-color=\"var(--color-content-tertiary)\"></span></div>\n              </div>\n              <div class=\"selcard__chip-row\">\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label\">Label</span><span class=\"selcard__chip-chevron\" data-ds-icon=\"chevron-right_solid\" data-ds-size=\"20\" data-ds-color=\"var(--color-content-tertiary)\"></span></div>\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label\">Label</span><span class=\"selcard__chip-chevron\" data-ds-icon=\"chevron-right_solid\" data-ds-size=\"20\" data-ds-color=\"var(--color-content-tertiary)\"></span></div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"guide-section\">\n        <div class=\"guide-subtitle\">Selected — 詳細オプション（4列 × 2行）+ 確認ボタン</div>\n        <div style=\"margin-top:var(--sizing-200);\">\n          <div class=\"selcard\" style=\"background:linear-gradient(33deg, var(--color-gradient-background-ai-surface-stop-1) 5.1%, var(--color-gradient-background-ai-surface-stop-2) 92.36%)\">\n            <div class=\"selcard__header\">\n              <div class=\"selcard__header-icon\"><span data-ds-icon=\"chevron-left_solid\" data-ds-size=\"24\" data-ds-color=\"var(--color-content-primary)\"></span></div>\n              <span class=\"selcard__header-text\">Text</span>\n            </div>\n            <div class=\"selcard__chip-group\">\n              <div class=\"selcard__chip-row\">\n                <div class=\"selcard__chip selcard__chip--sel\"><span class=\"selcard__chip-label--c\">Label</span></div>\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label--c\">Label</span></div>\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label--c\">Label</span></div>\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label--c\">Label</span></div>\n              </div>\n              <div class=\"selcard__chip-row\">\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label--c\">Label</span></div>\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label--c\">Label</span></div>\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label--c\">Label</span></div>\n                <div class=\"selcard__chip\"><span class=\"selcard__chip-label--c\">Label</span></div>\n              </div>\n            </div>\n            <div class=\"selcard__btn-wrap\"><button class=\"selcard__btn\">Label</button></div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"guide-section\">\n        <div class=\"guide-subtitle\">Chip states</div>\n        <div style=\"margin-top:var(--sizing-200);display:flex;gap:var(--spacing-300);flex-wrap:wrap;\">\n          <div class=\"selcard__chip\" style=\"width:calc(var(--sizing-100) * 40)\"><span class=\"selcard__chip-label\">Nav chip</span><span class=\"selcard__chip-chevron\" data-ds-icon=\"chevron-right_solid\" data-ds-size=\"20\" data-ds-color=\"var(--color-content-tertiary)\"></span></div>\n          <div class=\"selcard__chip selcard__chip--sel\" style=\"width:calc(var(--sizing-100) * 20)\"><span class=\"selcard__chip-label--c\">Selected</span></div>\n          <div class=\"selcard__chip\" style=\"width:calc(var(--sizing-100) * 20)\"><span class=\"selcard__chip-label--c\">Unselected</span></div>\n        </div>\n      </div>\n\n      <div class=\"guide-section\">\n        <div class=\"guide-subtitle\">Anatomy</div>\n        <div class=\"guide-body\">\n          <b>Container</b> — <code>selcard</code>: var(--size-card-width-lg) wide, border var(--border-width-100) var(--color-border-tertiary), radius var(--sizing-400), p var(--sizing-400), flex column, gap var(--sizing-500). Background: purple→blue 0.06 gradient (~37deg not-selected / ~33deg selected).<br>\n          <b>Header</b> — <code>selcard__header</code>: flex row, gap var(--sizing-100). Icon var(--sizing-600) + title var(--sizing-400) bold. Not-selected: Q gradient circle icon. Selected: back chevron-left icon.<br>\n          <b>Chip Group</b> — <code>selcard__chip-group</code>: flex column, gap var(--sizing-200). Each <code>selcard__chip-row</code>: flex row, gap var(--sizing-200).<br>\n          <b>Nav Chip</b> (not-selected): <code>selcard__chip</code>: flex:1, h var(--sizing-1000), radius var(--border-radius-full), border var(--color-gradient-border-secondary-stop-1). <code>selcard__chip-label</code> (flex:1) + chevron-right SVG (var(--sizing-500)).<br>\n          <b>Option Chip</b> (selected): <code>selcard__chip</code>: centered label only (<code>selcard__chip-label--c</code>). No chevron.<br>\n          <b>Selected Chip</b>: <code>selcard__chip--sel</code>: bg var(--color-background-selection-secondary), border var(--color-gradient-content-stop-1), text var(--color-content-key) bold.<br>\n          <b>Button</b>: <code>selcard__btn-wrap</code> (gradient border wrapper, calc(var(--border-width-100) * 1.5)) + <code>selcard__btn</code> (white bg, h var(--sizing-1000), radius var(--border-radius-full), var(--line-height-label-small) bold).\n        </div>\n      </div>\n    </div><!-- guide-card -->\n  "
  },
  "selector": ".selcard"
}