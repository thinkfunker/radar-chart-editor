{
  "name": "Accordion",
  "tier": "03_blocks",
  "key": "accordion",
  "type": "composition",
  "description": "Accordion organizes information into sections on detail pages.",
  "guidelines": {
    "summary": "The Accordion is a structural component that organizes information into sections on a detail page, allowing users to selectively view only the information they need.",
    "anatomy": [
      "Header (Trigger)",
      "Divider",
      "Content",
      "Slot"
    ],
    "style": {
      "state": [
        "Accordion is provided in a single type.",
        "Collapsed (Selected = false)",
        "Expanded (Selected = true)"
      ],
      "content_type": [
        "Default: テキストのみで構成されます。",
        "Custom: FigmaのSlot機能を活用することで、AccordionコンポーネントをDetachせずに、さまざまなタイプのAccordionを作成できます。"
      ]
    },
    "usage_guidelines": {
      "Information grouping": "Used for organizing groups of information within a detail page.",
      "Variable content": "Used for variable-length content such as descriptions, policies, and FAQs.",
      "Structuring": "Used when information needs to be structured at the section level."
    },
    "do_dont": {
      "do": [
        "💡 Control internal spacing within Content using 'gap'.",
        "💡 Use the entire Header area as a clickable region.",
        "💡 Maintain section-level hierarchy."
      ],
      "dont": [
        "🚫 Adjust internal spacing using 'margin'.",
        "🚫 Abuse the Accordion as a substitute for a general List."
      ]
    },
    "playground": {
      "controls": [
        {
          "id": "state",
          "label": "State",
          "type": "toggle",
          "options": [
            "collapsed",
            "expanded"
          ],
          "default": "collapsed"
        }
      ]
    },
    "_rawHtml": "\n<div class=\"guide-section\">\n            <div class=\"guide-title\">Purpose</div>\n            <div class=\"guide-body\">\n              Accordionは、詳細ページにおいて情報をセクション単位で整理し、ユーザーが必要な情報のみを選択的に確認できるようにする構造コンポーネントです。\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Anatomy</div>\n            <div class=\"guide-body\">\n              <ul>\n                <li><strong>Header (Trigger)</strong> — クリックで開閉トグル。ヘッダー全体がクリック可能</li>\n                <li><strong>Divider</strong> — アイテム下部の区切り線 <code>var(--color-border-tertiary)</code></li>\n                <li><strong>Content</strong> — 展開時に表示される説明テキスト領域</li>\n              </ul>\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Type</div>\n            <div class=\"guide-body\">\n              <p>Accordionは単一タイプのみ提供します。</p>\n              <ul>\n                <li><strong>Collapsed</strong> — <code>selected = false</code></li>\n                <li><strong>Expanded</strong> — <code>selected = true</code></li>\n              </ul>\n            </div>\n            <div class=\"guide-example-box\">\n              <div>\n                <div style=\"font-size: var(--font-size-0687); color: var(--color-content-tertiary); margin-bottom:var(--space-xs); font-family:monospace;\">Collapsed</div>\n                <div class=\"accordion\" style=\"width:calc(var(--sizing-100) * 65); border-radius:var(--radius-xs); overflow:hidden; box-shadow:0 var(--border-width-100) var(--spacing-100) var(--color-border-secondary);\">\n                  <div class=\"accordion-item\" style=\"pointer-events:none;\">\n                    <div class=\"accordion-header\">\n                      <span class=\"accordion-title\">Title text</span>\n                      <div class=\"accordion-icon\"><span data-ds-icon=\"chevron-down_solid\" data-ds-size=\"24\" data-ds-color=\"currentColor\"></span></div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <div>\n                <div style=\"font-size: var(--font-size-0687); color: var(--color-content-tertiary); margin-bottom:var(--space-xs); font-family:monospace;\">Expanded</div>\n                <div class=\"accordion\" style=\"width:calc(var(--sizing-100) * 65); border-radius:var(--radius-xs); overflow:hidden; box-shadow:0 var(--border-width-100) var(--spacing-100) var(--color-border-secondary);\">\n                  <div class=\"accordion-item open\" style=\"pointer-events:none;\">\n                    <div class=\"accordion-header\">\n                      <span class=\"accordion-title\">Title text</span>\n                      <div class=\"accordion-icon\"><span data-ds-icon=\"chevron-down_solid\" data-ds-size=\"24\" data-ds-color=\"currentColor\"></span></div>\n                    </div>\n                    <div class=\"accordion-content\">\n                      <p>Please Enter a Description text. Please Enter a Description text. Please Enter a Description text.</p>\n                    </div>\n                    <div class=\"accordion-divider\"></div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Usage Guidelines</div>\n            <div class=\"guide-body\">\n              <ul>\n                <li>詳細ページ内の情報グループ整理</li>\n                <li>説明、ポリシー、FAQなど可変長コンテンツ</li>\n                <li>セクション単位で情報構造化が必要な場合</li>\n              </ul>\n            </div>\n          </div>\n\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Do &amp; Don't</div>\n            <div class=\"guide-body\">\n              <p><strong>Do</strong></p>\n              <ul>\n                <li>Content内部の間隔は <code>gap</code> で制御する</li>\n                <li>Header全体をクリック領域として使用する</li>\n                <li>セクションレベルの階層を維持する</li>\n              </ul>\n              <p style=\"margin-top:var(--spacing-300);\"><strong>Don't</strong></p>\n              <ul>\n                <li><code>margin</code> で内部間隔を調整する</li>\n                <li>Listの代替として乱用する</li>\n              </ul>\n            </div>\n          </div>\n\n          <!-- HTMLコードスニペット -->\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Code</div>\n            <div class=\"guide-body\">\n              <pre style=\"background:var(--color-content-primary); border:var(--border-width-100) solid var(--shell-border); border-radius:var(--border-radius-200); padding:var(--spacing-400); font-size: var(--text-size-xs);; line-height:1.7; overflow-x:auto; color:var(--color-content-inverted); margin-top:var(--spacing-200);\"><code><span style=\"color:var(--color-content-tertiary)\">&lt;!-- Accordion コンテナ --&gt;</span>\n<span style=\"color:var(--color-content-key)\">&lt;div</span> <span style=\"color:var(--color-content-key)\">class</span>=<span style=\"color:var(--color-content-success)\">\"accordion\"</span><span style=\"color:var(--color-content-key)\">&gt;</span>\n\n  <span style=\"color:var(--color-content-tertiary)\">&lt;!-- 閉じたアイテム --&gt;</span>\n  <span style=\"color:var(--color-content-key)\">&lt;div</span> <span style=\"color:var(--color-content-key)\">class</span>=<span style=\"color:var(--color-content-success)\">\"accordion-item\"</span>\n       <span style=\"color:var(--color-content-key)\">onclick</span>=<span style=\"color:var(--color-content-success)\">\"toggleAccordion(this)\"</span><span style=\"color:var(--color-content-key)\">&gt;</span>\n    <span style=\"color:var(--color-content-key)\">&lt;div</span> <span style=\"color:var(--color-content-key)\">class</span>=<span style=\"color:var(--color-content-success)\">\"accordion-header\"</span><span style=\"color:var(--color-content-key)\">&gt;</span>\n      <span style=\"color:var(--color-content-key)\">&lt;span</span> <span style=\"color:var(--color-content-key)\">class</span>=<span style=\"color:var(--color-content-success)\">\"accordion-title\"</span><span style=\"color:var(--color-content-key)\">&gt;</span>Title text<span style=\"color:var(--color-content-key)\">&lt;/span&gt;</span>\n      <span style=\"color:var(--color-content-tertiary)\">&lt;!-- chevron icon --&gt;</span>\n    <span style=\"color:var(--color-content-key)\">&lt;/div&gt;</span>\n    <span style=\"color:var(--color-content-key)\">&lt;div</span> <span style=\"color:var(--color-content-key)\">class</span>=<span style=\"color:var(--color-content-success)\">\"accordion-content\"</span><span style=\"color:var(--color-content-key)\">&gt;</span>\n      <span style=\"color:var(--color-content-key)\">&lt;p&gt;</span>Description text<span style=\"color:var(--color-content-key)\">&lt;/p&gt;</span>\n    <span style=\"color:var(--color-content-key)\">&lt;/div&gt;</span>\n    <span style=\"color:var(--color-content-key)\">&lt;div</span> <span style=\"color:var(--color-content-key)\">class</span>=<span style=\"color:var(--color-content-success)\">\"accordion-divider\"</span><span style=\"color:var(--color-content-key)\">&gt;&lt;/div&gt;</span>\n  <span style=\"color:var(--color-content-key)\">&lt;/div&gt;</span>\n\n  <span style=\"color:var(--color-content-tertiary)\">&lt;!-- 開いたアイテム: classに \"open\" を追加 --&gt;</span>\n  <span style=\"color:var(--color-content-key)\">&lt;div</span> <span style=\"color:var(--color-content-key)\">class</span>=<span style=\"color:var(--color-content-success)\">\"accordion-item <strong>open</strong>\"</span> ...<span style=\"color:var(--color-content-key)\">&gt;</span>\n    ...\n  <span style=\"color:var(--color-content-key)\">&lt;/div&gt;</span>\n\n<span style=\"color:var(--color-content-key)\">&lt;/div&gt;</span></code></pre>\n            </div>\n          </div>\n\n          <!-- デザイントークン -->\n          <div class=\"guide-section\">\n            <div class=\"guide-title\">Design Tokens</div>\n            <div class=\"guide-body\">\n              <table style=\"width:100%; border-collapse:collapse; font-size: var(--text-size-xs);;\">\n                <thead>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border);\">\n                    <th style=\"text-align:left; padding:var(--spacing-200) 0; color:var(--shell-muted); font-weight:600;\">Property</th>\n                    <th style=\"text-align:left; padding:var(--spacing-200) 0; color:var(--shell-muted); font-weight:600;\">Token</th>\n                    <th style=\"text-align:left; padding:var(--spacing-200) 0; color:var(--shell-muted); font-weight:600;\">Value</th>\n                  </tr>\n                </thead>\n                <tbody>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border)09;\">\n                    <td style=\"padding:var(--space-lg) 0; color:var(--shell-muted);\">Background</td>\n                    <td><code style=\"font-size: var(--text-size-xs);;\">--background/primary</code></td>\n                    <td style=\"color:var(--shell-muted); font-size: var(--text-size-xs);;\">var(--color-background-white)</td>\n                  </tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border)09;\">\n                    <td style=\"padding:var(--space-lg) 0; color:var(--shell-muted);\">Hover BG</td>\n                    <td><code style=\"font-size: var(--text-size-xs);;\">--state/hover-primary</code></td>\n                    <td style=\"color:var(--shell-muted); font-size: var(--text-size-xs);;\">var(--color-background-disabled-accent)</td>\n                  </tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border)09;\">\n                    <td style=\"padding:var(--space-lg) 0; color:var(--shell-muted);\">Title Color</td>\n                    <td><code style=\"font-size: var(--text-size-xs);;\">--content/primary</code></td>\n                    <td style=\"color:var(--shell-muted); font-size: var(--text-size-xs);;\">var(--color-content-primary)</td>\n                  </tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border)09;\">\n                    <td style=\"padding:var(--space-lg) 0; color:var(--shell-muted);\">Content Color</td>\n                    <td><code style=\"font-size: var(--text-size-xs);;\">--content/placeholder</code></td>\n                    <td style=\"color:var(--shell-muted); font-size: var(--text-size-xs);;\">var(--color-content-tertiary)</td>\n                  </tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border)09;\">\n                    <td style=\"padding:var(--space-lg) 0; color:var(--shell-muted);\">Divider</td>\n                    <td><code style=\"font-size: var(--text-size-xs);;\">--border/tertiary</code></td>\n                    <td style=\"color:var(--shell-muted); font-size: var(--text-size-xs);;\">var(--color-border-tertiary)</td>\n                  </tr>\n                  <tr style=\"border-bottom:var(--border-width-100) solid var(--shell-border)09;\">\n                    <td style=\"padding:var(--space-lg) 0; color:var(--shell-muted);\">Header height</td>\n                    <td><code style=\"font-size: var(--text-size-xs);;\">min-height</code></td>\n                    <td style=\"color:var(--shell-muted); font-size: var(--text-size-xs);;\">var(--sizing-1200)</td>\n                  </tr>\n                  <tr>\n                    <td style=\"padding:var(--space-lg) 0; color:var(--shell-muted);\">Padding H/V</td>\n                    <td><code style=\"font-size: var(--text-size-xs);;\">--spacing/400, --spacing/200</code></td>\n                    <td style=\"color:var(--shell-muted); font-size: var(--text-size-xs);;\">var(--sizing-400) / var(--sizing-200)</td>\n                  </tr>\n                </tbody>\n              </table>\n            </div>\n          </div>\n    ",
    "purpose": "Accordionは、詳細ページにおいて情報をセクション単位で整理し、ユーザーが必要な情報のみを選択的に確認できるようにする構造コンポーネントです。",
    "slot": "Figmaで提供されているSlot機能を利用することで、ComponentをDetachせずに、任意のInstanceへ置き換えることが可能です。この機能を活用することで、さまざまなタイプのAccordionを作成できます。",
    "do": [
      "Content内部の間隔はgapで制御する",
      "Header全体をクリック領域として使用する",
      "セクションレベルの階層を維持する"
    ],
    "dont": [
      "marginで内部間隔を調整する",
      "Listの代替として乱用する"
    ]
  },
  "selector": ".accordion"
}