{
  "name": "Basic Card",
  "tier": "03_blocks",
  "key": "card",
  "type": "composition",
  "description": "",
  "guidelines": {
    "_rawHtml": "\n    <div class=\"guide-card\">\n      <div class=\"guide-section\">\n        <div class=\"guide-title\">Card</div>\n        <div class=\"guide-body\">Info / List / Review の3種類のカードタイプで構成されたコンポーネントシステムです。共通トークンを共有し border-radius var(--sizing-300)（small） / var(--sizing-400)(large)を使い分けます。</div>\n      </div>\n\n      <div class=\"guide-section\">\n        <div class=\"guide-subtitle\">List Card — Minimal</div>\n        <div style=\"margin-top:var(--spacing-200);\">\n          <div class=\"card card--r12 card-list-min\">\n            <div class=\"card__title\">商品タイトル</div>\n            <div class=\"card__sub\">ブランド名 · カテゴリ</div>\n            <div class=\"card__meta\">追加説明テキストがここに入ります</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"guide-section\">\n        <div class=\"guide-subtitle\">List Card — Thumbnail</div>\n        <div style=\"margin-top:var(--spacing-200);\">\n          <div class=\"card card--r12 card-list-thumb\">\n            <div class=\"card-list-thumb__body\">\n              <div class=\"card__title\">商品タイトル</div>\n              <div class=\"card__sub\">ブランド名</div>\n              <div class=\"card__body\" style=\"overflow:hidden;white-space:nowrap;text-overflow:ellipsis;\">詳細説明がここに入ります.</div>\n            </div>\n            <div class=\"card-list-thumb__img card__photo-bg\"></div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"guide-section\">\n        <div class=\"guide-subtitle\">List Card — Gallery</div>\n        <div style=\"margin-top:var(--spacing-200);\">\n          <div class=\"card card--r16 card-list-gallery\">\n            <div class=\"card__title-lg\">ギャラリータイトル</div>\n            <div class=\"card__gallery\">\n              <div class=\"card__gallery-img card__photo-bg\"></div>\n              <div class=\"card__gallery-img card__photo-bg\"></div>\n              <div class=\"card__gallery-img card__photo-bg\"></div>\n            </div>\n            <button class=\"card__btn\">詳しく見る</button>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"guide-section\">\n        <div class=\"guide-subtitle\">Review Card</div>\n        <div style=\"margin-top:var(--spacing-200);\">\n          <div class=\"card card--r16 card-review\">\n            <div class=\"card-review__header\">\n              <div class=\"card__title-lg\">レビュータイトル</div>\n              <div class=\"card__body\">サブテキスト説明が入ります</div>\n            </div>\n            <div class=\"card__rating-row\">\n              <div class=\"card__stars\"><span class=\"card__star\">★</span><span class=\"card__star\">★</span><span class=\"card__star\">★</span><span class=\"card__star\">★</span><span class=\"card__star\">★</span></div>\n              <span class=\"card__meta\">5.0（1,234件のレビュー）</span>\n            </div>\n            <div class=\"card-review__gallery\">\n              <div class=\"card-review__gallery-img card__photo-bg\"></div>\n              <div class=\"card-review__gallery-img card__photo-bg\"></div>\n              <div class=\"card-review__gallery-img card__photo-bg\"></div>\n            </div>\n            <div class=\"card__infobox\">\n              <div class=\"card__body\">追加詳細情報エリアです。</div>\n              <a href=\"#\" class=\"card__link\">もっと見る</a>\n            </div>\n            <div class=\"card__tags\">\n              <span class=\"card__tag\">絶景スポット</span><span class=\"card__tag\">ファミリー</span><span class=\"card__tag\">駐車場あり</span><span class=\"card__tag\">待ち時間なし</span><span class=\"card__tag\">コスパ良し</span><span class=\"card__tag\">リピート</span>\n            </div>\n            <button class=\"card__btn\">予約する</button>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"guide-section\">\n        <div class=\"guide-subtitle\">Info Card</div>\n        <div style=\"margin-top:var(--spacing-200);\">\n          <div class=\"card card--r12 card-info\">\n            <div class=\"card-info__icon\"><span data-ds-icon=\"star_solid_full\" data-ds-size=\"24\" data-ds-color=\"var(--color-content-inverted)\"></span></div>\n            <div class=\"card-info__text\">\n              <div class=\"card__title\">AIサービス名</div>\n              <div class=\"card__meta\">サービスカテゴリ</div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"guide-section\">\n        <div class=\"guide-subtitle\">Anatomy</div>\n        <div class=\"guide-body\">\n          <b>Base</b> — <code>card</code>: white bg, <code>var(--color-border-tertiary)</code> border. <code>card--r12</code> (var(--sizing-300)) / <code>card--r16</code> (var(--sizing-400)).<br>\n          <b>List min</b> — <code>card-list-min</code>: flex column, padding var(--sizing-400), gap var(--sizing-200).<br>\n          <b>List thumb</b> — <code>card-list-thumb</code>: flex row, gap var(--sizing-300). サムネイル <code>card-list-thumb__img</code> 60×var(--sizing-1500), radius var(--sizing-200).<br>\n          <b>List gallery</b> — <code>card-list-gallery</code>: flex column, gap var(--sizing-300)。画像3列 <code>card__gallery</code> gap var(--sizing-100), 各var(--size-gallery-thumb-height)高さ.<br>\n          <b>Review</b> — <code>card-review</code>: flex column, gap var(--sizing-300)。星評価 <code>card__stars</code>、画像 <code>card-review__gallery</code>, タグ <code>card__tag</code> (var(--color-background-tertiary), radius var(--sizing-100)).<br>\n          <b>Info</b> — <code>card-info</code>: flex column, calc(var(--sizing-100) * 49) wide。アイコン 48×var(--sizing-1200) + テキスト。\n        </div>\n      </div>\n    </div><!-- guide-card -->\n  "
  },
  "selector": ".card"
}